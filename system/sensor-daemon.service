[Unit]
Description=HA Panel Sensor Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/ha-panel/repo/sensor-daemon
ExecStart=/opt/ha-panel/venv/bin/python main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
